# ============================================================
# Pipecat Telephony Voice Agent — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# ── AI Provider Keys ────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Server (Pipecat WebSocket — FreeSWITCH connects here) ───
# Keep HOST as 127.0.0.1 — only FreeSWITCH on the same machine connects
HOST=127.0.0.1
PORT=8765

# ── Agent Personality ────────────────────────────────────────
AGENT_NAME=Aria
SYSTEM_PROMPT=You are Aria, a helpful voice assistant answering a phone call. Be concise, friendly, and natural. This is a voice call so keep responses short — two or three sentences max unless asked for more detail.

# ── Audio (must match mod_audio_stream dialplan config) ──────
# 16000 = 16 kHz — best quality for Deepgram, configure FreeSWITCH to match
SAMPLE_RATE=16000

# ── Groq / LLM ───────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

# ── Deepgram / STT ───────────────────────────────────────────
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-US
DEEPGRAM_ENDPOINTING_MS=300

# ── ElevenLabs / TTS ─────────────────────────────────────────
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
