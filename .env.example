# ============================================================
# Pipecat Telephony Voice Agent — Environment Variables
# Janus AudioBridge transport edition
# Copy this file to .env and fill in your API keys
# ============================================================

# -- AI Provider Keys --
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# -- Agent Personality --
AGENT_NAME=Aria
SYSTEM_PROMPT=You are Aria, a helpful voice assistant answering a phone call. Be concise, friendly, and natural. Keep replies short unless asked for detail.

# -- Core Audio --
# Pipeline sample rate (Hz)
SAMPLE_RATE=16000

# Janus/aiortc audio normalization settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CODEC=opus

# -- Janus WebRTC Transport --
JANUS_WS_URL=ws://127.0.0.1:8188
JANUS_REST_URL=http://127.0.0.1:8088/janus
ROOM_ID=7007
ROOM_PIN=7007
JANUS_DISPLAY_NAME=pipecat-voiceagent
JANUS_KEEPALIVE_INTERVAL=30

# -- Groq / LLM --
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

# -- Deepgram / STT --
DEEPGRAM_MODEL=nova-3-general
DEEPGRAM_LANGUAGE=en-US
DEEPGRAM_ENDPOINTING_MS=300

# -- ElevenLabs / TTS --
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# -- Logging --
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
